@using System.Globalization
<div class="prow">
    <span class="pname">@Label</span>
    <input type="range" min="@Fmt(Min)" max="@Fmt(Max)" step="@Fmt(Step)"
           value="@Fmt(Value)" @oninput="OnInput" aria-label="@Label" />
    <input class="pnum" type="number" min="@Fmt(Min)" max="@Fmt(Max)" step="@Fmt(Step)"
           value="@Fmt(Value)" @oninput="OnInput" aria-label="@Label" />
</div>

@code {
    [Parameter] [EditorRequired] public string Label { get; set; } = "";
    [Parameter] public float Value { get; set; }
    [Parameter] public EventCallback<float> ValueChanged { get; set; }
    [Parameter] public float Min { get; set; }
    [Parameter] public float Max { get; set; } = 1f;
    [Parameter] public float Step { get; set; } = 0.01f;

    private static string Fmt(float v)
    {
        return v.ToString(CultureInfo.InvariantCulture);
    }

    private Task OnInput(ChangeEventArgs e)
    {
        if (float.TryParse(e.Value?.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var v))
        {
            return ValueChanged.InvokeAsync(v);
        }

        return Task.CompletedTask;
    }

}
